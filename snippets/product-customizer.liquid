{% comment %}
  Front/Back shirt customizer - see md/PRD-shirt-customizer.md.

  Printify-style split layout, rendered from sections/main-product.liquid:
  - part: 'preview'  -> the <product-customizer> element (config + canvas + tabs +
                        status + photo strip). Rendered in the LEFT media column.
  - part: 'controls' -> the controls panel + hidden property inputs. Rendered in the
                        RIGHT info column by the 'customizer' block.
  - part: 'all'      -> both together (fallback / single-column).

  The preview element owns all JS; it finds its controls in the right column by id
  (data-controls). Hidden inputs bind to the product form via form="{{ product_form_id }}"
  so Dawn's AJAX product-form.js serializes them with no fork. Config is read from the
  metaobject custom.customizer, falling back to flat product metafields, then defaults.

  Accepts: product, block, product_form_id, section_id, part.
{% endcomment %}

{%- assign part = part | default: 'all' -%}
{%- assign controls_id = 'customizer-controls-' | append: section_id -%}

{%- if part == 'preview' or part == 'all' -%}
  {{ 'product-customizer.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-customizer.js' | asset_url }}" defer="defer"></script>

  {%- liquid
    assign cfg = product.metafields.custom.customizer.value

    # Metaobject fields are read via .value; fall back to direct access, then to
    # flat product metafields, then to a default. This tolerates however the
    # merchant stored each field (list / json / single).
    assign print_area_front = cfg.print_area_front.value
    if print_area_front == blank
      assign print_area_front = cfg.print_area_front
    endif
    if print_area_front == blank
      assign print_area_front = product.metafields.custom.print_areas.value.front
    endif

    assign print_area_back = cfg.print_area_back.value
    if print_area_back == blank
      assign print_area_back = cfg.print_area_back
    endif
    if print_area_back == blank
      assign print_area_back = product.metafields.custom.print_areas.value.back
    endif

    assign fonts = cfg.fonts.value
    if fonts == blank
      assign fonts = cfg.fonts
    endif
    if fonts == blank
      assign fonts = product.metafields.custom.fonts.value
    endif

    assign presets = cfg.preset_texts.value
    if presets == blank
      assign presets = cfg.preset_texts
    endif
    if presets == blank
      assign presets = product.metafields.custom.preset_texts.value
    endif

    assign max_chars = cfg.max_chars.value
    if max_chars == blank
      assign max_chars = cfg.max_chars
    endif
    if max_chars == blank
      assign max_chars = product.metafields.custom.max_chars.value
    endif
    if max_chars == blank
      assign max_chars = 24
    endif

    assign enable_back = cfg.enable_back.value
    if enable_back == blank
      assign enable_back = cfg.enable_back
    endif
    if enable_back == blank
      assign enable_back = product.metafields.custom.enable_back.value
    endif
    if enable_back == blank
      assign enable_back = true
    endif
  -%}

  <product-customizer
    class="product-customizer product-customizer--preview"
    data-section-id="{{ section_id }}"
    data-product-form-id="{{ product_form_id }}"
    data-product-id="{{ product.id }}"
    data-upload-url="{{ block.settings.mockup_upload_url }}"
    data-controls="{{ controls_id }}"
  >
    <script type="application/json" data-customizer-config>
      {
        "printAreaFront": {% if print_area_front != blank %}{{ print_area_front | json }}{% else %}{"x":0.30,"y":0.32,"w":0.40,"h":0.34}{% endif %},
        "printAreaBack": {% if print_area_back != blank %}{{ print_area_back | json }}{% else %}{"x":0.28,"y":0.28,"w":0.44,"h":0.40}{% endif %},
        "fonts": {% if fonts != blank %}{{ fonts | json }}{% else %}["Anton","Oswald","Roboto Slab","Pacifico","Space Mono"]{% endif %},
        "presets": {% if presets != blank %}{{ presets | json }}{% else %}[]{% endif %},
        "maxChars": {{ max_chars | json }},
        "enableBack": {{ enable_back | json }},
        "selectedVariantId": {{ product.selected_or_first_available_variant.id | json }},
        "productImage": {% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 1400 | json }}{% else %}null{% endif %},
        "colorOption": {% if product.options_with_values.size > 0 %}{{ product.options_with_values[0].name | json }}{% else %}null{% endif %},
        "variants": {
          {%- for variant in product.variants -%}
            {%- liquid
              assign front_url = ''
              if variant.metafields.custom.mockup_front.value != blank
                assign front_url = variant.metafields.custom.mockup_front.value | image_url: width: 1400
              elsif variant.featured_image != blank
                assign front_url = variant.featured_image | image_url: width: 1400
              endif

              assign back_url = ''
              if variant.metafields.custom.mockup_back.value != blank
                assign back_url = variant.metafields.custom.mockup_back.value | image_url: width: 1400
              endif
            -%}
            "{{ variant.id }}": {
              "title": {{ variant.title | json }},
              "color": {{ variant.option1 | json }},
              "front": {{ front_url | json }},
              "back": {{ back_url | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        }
      }
    </script>

    <div
      class="product-customizer__tabs"
      data-customizer-tabs
      role="tablist"
      aria-label="Choose side to customize"
      hidden
    ></div>

    <div class="product-customizer__preview" data-customizer-preview>
      <canvas class="product-customizer__canvas" data-customizer-canvas></canvas>
    </div>

    <span class="visually-hidden" data-customizer-status role="status" aria-live="polite"></span>

    {%- comment -%}
      Interactive color/side thumbnail selector. Built by product-customizer.js from
      the per-variant base images; clicking a thumbnail drives the variant picker
      (color) and the front/back side. Hidden until JS populates it.
    {%- endcomment -%}
    <div
      class="product-customizer__strip"
      data-customizer-strip
      role="group"
      aria-label="Choose a color and side to preview"
      hidden
    ></div>
  </product-customizer>
{%- endif -%}

{%- if part == 'controls' or part == 'all' -%}
  <div id="{{ controls_id }}" class="product-customizer product-customizer--controls" {{ block.shopify_attributes }}>
    {%- if block.settings.heading != blank -%}
      <h2 class="product-customizer__heading h4">{{ block.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="product-customizer__panel" data-customizer-panel></div>

    {%- comment -%}
      Line item properties (PRD 7). Bound to the product form via the form attribute.
      JS enables+populates each side only when it has text; empty sides stay disabled
      and are stripped from the order. Underscore props are filled in the mockup phase.
    {%- endcomment -%}
    <div class="product-customizer__properties">
      <input type="hidden" name="properties[Front Text]"      data-prop="front-text"   form="{{ product_form_id }}">
      <input type="hidden" name="properties[Front Font]"      data-prop="front-font"   form="{{ product_form_id }}">
      <input type="hidden" name="properties[Front Color]"     data-prop="front-color"  form="{{ product_form_id }}">
      <input type="hidden" name="properties[Front Placement]" data-prop="front-place"  form="{{ product_form_id }}">
      <input type="hidden" name="properties[Back Text]"       data-prop="back-text"    form="{{ product_form_id }}">
      <input type="hidden" name="properties[Back Font]"       data-prop="back-font"    form="{{ product_form_id }}">
      <input type="hidden" name="properties[Back Color]"      data-prop="back-color"   form="{{ product_form_id }}">
      <input type="hidden" name="properties[Back Placement]"  data-prop="back-place"   form="{{ product_form_id }}">
      <input type="hidden" name="properties[_Front Mockup]"   data-prop="front-mockup" form="{{ product_form_id }}">
      <input type="hidden" name="properties[_Back Mockup]"    data-prop="back-mockup"  form="{{ product_form_id }}">
      <input type="hidden" name="properties[_Design ID]"      data-prop="design-id"    form="{{ product_form_id }}">
    </div>
  </div>
{%- endif -%}
